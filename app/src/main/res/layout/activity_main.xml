<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Phase label -->
        <TextView
            android:id="@+id/phaseLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="READY"
            android:textColor="@color/getready"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="8dp" />

        <!-- Big countdown -->
        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/circle_surface">

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="00:30"
                android:textColor="@color/text"
                android:textSize="72sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </FrameLayout>

        <!-- Round + total remaining -->
        <TextView
            android:id="@+id/roundText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Round 0 / 0"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/totalText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total left 20:00"
            android:textColor="@color/text_dim"
            android:textSize="15sp"
            android:layout_marginTop="2dp" />

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/startPauseBtn"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:text="START"
                android:textSize="18sp" />

            <Button
                android:id="@+id/resetBtn"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:text="RESET"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Settings card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/circle_surface_rect"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETTINGS"
                android:textColor="@color/text_dim"
                android:textSize="13sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <include layout="@layout/row_setting"
                android:id="@+id/rowTotal" />
            <include layout="@layout/row_setting"
                android:id="@+id/rowWork" />
            <include layout="@layout/row_setting"
                android:id="@+id/rowRest" />
            <include layout="@layout/row_setting"
                android:id="@+id/rowBeep" />
            <include layout="@layout/row_setting"
                android:id="@+id/rowPrep" />

            <CheckBox
                android:id="@+id/vibrateCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vibrate on phase change"
                android:textColor="@color/text"
                android:checked="true"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />
    </LinearLayout>
</ScrollView>
